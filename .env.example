# .env.example
# =============================================================================
# PACT CONTRACT TESTING - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and adjust values for your environment
# =============================================================================

# -----------------------------------------------------------------------------
# Pact Broker Configuration
# -----------------------------------------------------------------------------
# URL where your Pact Broker is running
PACT_BROKER_BASE_URL=http://localhost:9292

# Authentication (if enabled on your broker)
PACT_BROKER_USERNAME=
PACT_BROKER_PASSWORD=

# Alternative: Token-based auth
PACT_BROKER_TOKEN=

# -----------------------------------------------------------------------------
# Provider Configuration
# -----------------------------------------------------------------------------
# DummyJSON provider URL (local Docker or remote)
PROVIDER_BASE_URL=http://localhost:3000

# Provider name (must match consumer contract)
PROVIDER_NAME=DummyJSON

# -----------------------------------------------------------------------------
# Consumer Configuration
# -----------------------------------------------------------------------------
# Consumer application name
CONSUMER_NAME=FrontendApp

# -----------------------------------------------------------------------------
# Versioning
# -----------------------------------------------------------------------------
# Application version (typically set by CI from git SHA)
APP_VERSION=1.0.0

# Git branch or tag (for Pact Broker tagging)
GIT_BRANCH=main

# Git commit SHA
GIT_COMMIT=local

# -----------------------------------------------------------------------------
# CI/CD Configuration
# -----------------------------------------------------------------------------
# Set to 'true' in CI environments
CI=false

# Enable verbose Pact logging
PACT_LOG_LEVEL=info

# Publish verification results to broker
PACT_PUBLISH_VERIFICATION_RESULTS=false

# -----------------------------------------------------------------------------
# Environments (for can-i-deploy)
# -----------------------------------------------------------------------------
# Target deployment environment
DEPLOY_ENVIRONMENT=production
