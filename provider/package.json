{
  "name": "provider",
  "version": "1.0.0",
  "description": "Provider verification tests for DummyJSON API using Pact",
  "scripts": {
    "clean": "rm -rf dist coverage",
    "test": "jest",
    "test:pact": "jest --testMatch='**/*.verification.spec.ts' --runInBand",
    "test:pact:verbose": "jest --testMatch='**/*.verification.spec.ts' --runInBand --verbose",
    "verify": "jest --testMatch='**/*.verification.spec.ts' --runInBand",
    "verify:ci": "jest --testMatch='**/*.verification.spec.ts' --runInBand --ci"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^12.1.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/node-fetch": "^2.6.9",
    "jest": "^29.7.0",
    "jest-html-reporters": "^3.1.7",
    "node-fetch": "^2.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.0"
  },
  "pact": {
    "provider": "DummyJSON",
    "pactBrokerUrl": "http://localhost:9292"
  }
}
